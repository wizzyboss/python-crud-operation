def is_online():
    try:
        socket.create_connection(("8.8.8.8", 53), timeout=2)
        return True
    except:
        return False

def background_sync_worker():
    """This function runs in the background forever"""
    while True:
        if is_online():
            try:
                conn = pymysql.connect(host='127.0.0.1', user='root', password='', database='store_db', cursorclass=pymysql.cursors.DictCursor)
                with conn.cursor() as cursor:
                    # Look for anything not synced
                    cursor.execute("SELECT id, label, price FROM store_db WHERE synced = 0")
                    rows = cursor.fetchall()
                    
                    if rows:
                        print(f"Internet back! Syncing {len(rows)} items...")
                        data = [{"label": r['label'], "price": float(r['price'])} for r in rows]
                        supabase.table("store_db").insert(data).execute()
                        
                        # Mark as done
                        ids = [r['id'] for r in rows]
                        cursor.execute(f"UPDATE store_db SET synced = 1 WHERE id IN ({','.join(['%s']*len(ids))})", tuple(ids))
                        conn.commit()
                conn.close()
            except Exception as e:
                print(f"Background Sync Error: {e}")
        
        time.sleep(5) # Check every 5 seconds

def save_to_local():
    """Saves to XAMPP immediately"""
    try:
        data = []
        for i in range(5):
            l, p = label_entries[i].get(), price_entries[i].get()
            if l and p:
                data.append((l, float(p)))
        
        if not data:
            messagebox.showerror("Error", "Enter at least one item")
            return

        db = pymysql.connect(host='127.0.0.1', user='root', password='', database='store_db')
        with db.cursor() as cur:
            cur.executemany("INSERT INTO store_db (label, price, synced) VALUES (%s, %s, 0)", data)
        db.commit()
        db.close()
        
        messagebox.showinfo("Saved", "Saved locally. Background sync is active!")
        for e in label_entries + price_entries: e.delete(0, tk.END)
    except Exception as e:
        messagebox.showerror("Error", str(e))

